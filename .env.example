# Telegram Bot Token (from @BotFather)
BOT_TOKEN=

# User registry: path to the JSON file listing registered users
# [{ "id": <telegramUserId>, "name": "...", "email": "forwarder@gmail.com" }, ...].
# Replaces ALLOWED_USER_ID. The "email" of each user is the attribution key for
# forwarded mail (a user with no email can use the bot but cannot forward).
# Copy users.json.example to users.json and fill it in. Defaults to ./users.json.
USERS_FILE=./users.json

# DeepSeek API (OpenAI-compatible) — optional for now
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Data directory (defaults to ./data)
DATA_DIR=./data

# Qdrant vector DB URL (defaults to http://localhost:6333)
QDRANT_URL=http://localhost:6333

# Embedding model name (HuggingFace Transformers.js)
EMBEDDING_MODEL=Xenova/multilingual-e5-small

# Web UI for drag-and-drop file upload (optional, defaults to port 3000)
# WEB_PORT=3000
# WEB_HOST=0.0.0.0

# External URL for the web UI (base, without token).
# The bot appends /u/<userId>?token=<sessionToken> for each user.
# WEB_URL=http://<server-host>:3003

# When you press "Subir" the bot offers two upload links so you can pick the
# right one depending on where you are. Set the base URL (host + port, no path).
# WEB_URL_LOCAL: reachable on the home WiFi / LAN (server's local IP).
# WEB_URL_TAILSCALE: reachable from anywhere over Tailscale (server's Tailscale IP).
# WEB_URL_LOCAL=http://192.168.1.50:3003
# WEB_URL_TAILSCALE=http://100.102.109.64:3003

# Session lifecycle (per-user, in-memory). Drives conversation memory and the
# expiring web upload link.
# SESSION_TTL_SECONDS: total inactivity before the session closes (default 1800 = 30 min).
# SESSION_WARNING_GRACE_SECONDS: seconds before close when the bot warns (default 120; must be < TTL).
# SESSION_SWEEP_SECONDS: how often the sweep checks for warnings/closes (default 30).
# SESSION_TTL_SECONDS=1800
# SESSION_WARNING_GRACE_SECONDS=120
# SESSION_SWEEP_SECONDS=30

# Email ingestion (Gmail poller). Disabled by default so the app boots without
# Gmail credentials. When EMAIL_ENABLED=true the app polls a dedicated Gmail
# mailbox and ingests messages forwarded from a registered user's "email".
# EMAIL_ENABLED=false
# EMAIL_POLL_SECONDS=300              # how often to poll the mailbox
# EMAIL_QUERY_DAYS=7                  # Gmail "newer_than:Nd" window
# Gmail API OAuth (shared with a future Calendar adapter). Get a refresh token
# once via: bun run scripts/google-auth.ts
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=
# GMAIL_USER=mailbox@gmail.com        # the dedicated shared mailbox address

# Deploy target (Linux server running the app in Docker)
# DEPLOY_USER=
# DEPLOY_HOST=
# DEPLOY_PATH=
