# Copy to .env and fill in real values. NEVER commit the real .env.

# Telegram
TELEGRAM_BOT_TOKEN=

# LLM provider (DeepSeek — OpenAI-compatible API)
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Embeddings (local — DeepSeek does not provide an embeddings endpoint)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=Xenova/multilingual-e5-small
MODEL_CACHE_DIR=./data/models

# Web upload UI (LAN-only — do NOT expose publicly)
WEB_UI_ENABLED=true
WEB_HOST=0.0.0.0
WEB_PORT=3002
WEB_BASE_URL=http://home-server:3002
UPLOAD_TOKEN_TTL_MIN=10

# Storage
DATA_DIR=./data

# Allowlist (REQUIRED): comma-separated Telegram user IDs allowed to use the bot
ALLOWED_USER_IDS=

# Limits (sensible defaults)
RATE_LIMIT_QA_PER_HOUR=30
MAX_UPLOAD_MB=200
INGEST_CONCURRENCY=1
